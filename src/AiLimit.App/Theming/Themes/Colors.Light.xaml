<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surface -->
    <Color x:Key="Color.Surface.Window">#F6F8FA</Color>
    <Color x:Key="Color.Surface.TitleBar">#FFFFFF</Color>
    <Color x:Key="Color.Surface.Card">#FFFFFF</Color>
    <Color x:Key="Color.Surface.CardElevated">#F0F3F6</Color>
    <Color x:Key="Color.Surface.CardInverse">#FAFBFC</Color>
    <Color x:Key="Color.Surface.Overlay">#F0FFFFFF</Color>

    <!-- Text -->
    <Color x:Key="Color.Text.Primary">#1F2328</Color>
    <Color x:Key="Color.Text.Secondary">#656D76</Color>
    <Color x:Key="Color.Text.Tertiary">#848D97</Color>
    <Color x:Key="Color.Text.OnAccent">#FFFFFF</Color>
    <Color x:Key="Color.Text.Muted">#6E7681</Color>

    <!-- Border -->
    <Color x:Key="Color.Border.Default">#D0D7DE</Color>
    <Color x:Key="Color.Border.Subtle">#E1E4E8</Color>
    <Color x:Key="Color.Border.Strong">#0969DA</Color>
    <Color x:Key="Color.Border.WidgetCard">#D0D7DE</Color>

    <!-- Accent -->
    <Color x:Key="Color.Accent.Primary">#0969DA</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#0860CA</Color>
    <Color x:Key="Color.Accent.PrimaryPressed">#0550AE</Color>
    <Color x:Key="Color.Accent.Link">#0969DA</Color>

    <!-- Status -->
    <Color x:Key="Color.Status.Fresh">#1A7F37</Color>
    <Color x:Key="Color.Status.FreshSoft">#2DA44E</Color>
    <Color x:Key="Color.Status.Warning">#9A6700</Color>
    <Color x:Key="Color.Status.Refreshing">#BF8700</Color>
    <Color x:Key="Color.Status.Stale">#BC4C00</Color>
    <Color x:Key="Color.Status.Failed">#CF222E</Color>
    <Color x:Key="Color.Status.FailedSoft">#A40E26</Color>
    <Color x:Key="Color.Status.FailedFaint">#FF8182</Color>
    <Color x:Key="Color.Status.Neutral">#656D76</Color>

    <!-- Urgency -->
    <Color x:Key="Color.Urgency.Critical">#CF222E</Color>
    <Color x:Key="Color.Urgency.High">#BF8700</Color>
    <Color x:Key="Color.Urgency.Medium">#0969DA</Color>
    <Color x:Key="Color.Urgency.Low">#1A7F37</Color>

    <!-- Brand -->
    <Color x:Key="Color.Brand.Claude">#D2620A</Color>
    <Color x:Key="Color.Brand.Codex">#1A7F37</Color>
    <Color x:Key="Color.Brand.Antigravity">#1A56DB</Color>
    <Color x:Key="Color.Brand.Unknown">#5E48E8</Color>

    <!-- Badge -->
    <Color x:Key="Color.Badge.Cloud.Fg">#0550AE</Color>
    <Color x:Key="Color.Badge.Cloud.Bg">#DDF4FF</Color>
    <Color x:Key="Color.Badge.Cloud.Border">#0969DA</Color>
    <Color x:Key="Color.Badge.Ide.Fg">#4C2889</Color>
    <Color x:Key="Color.Badge.Ide.Bg">#FBEFFF</Color>
    <Color x:Key="Color.Badge.Ide.Border">#8250DF</Color>
    <Color x:Key="Color.Badge.FailureFg">#A40E26</Color>
    <Color x:Key="Color.Badge.FailureBg">#FFEBE9</Color>
    <Color x:Key="Color.Badge.FailureBorder">#CF222E</Color>
    <Color x:Key="Color.Badge.OkFg">#1A7F37</Color>
    <Color x:Key="Color.Badge.OkBg">#DAFBE1</Color>
    <Color x:Key="Color.Badge.OkBorder">#2DA44E</Color>

    <!-- Indicator -->
    <Color x:Key="Color.Indicator.Clean">#2DA44E</Color>
    <Color x:Key="Color.Indicator.Dirty">#CF222E</Color>

</ResourceDictionary>

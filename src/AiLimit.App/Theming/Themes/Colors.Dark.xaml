<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Surface -->
    <Color x:Key="Color.Surface.Window">#0D1117</Color>
    <Color x:Key="Color.Surface.TitleBar">#010409</Color>
    <Color x:Key="Color.Surface.Card">#161B22</Color>
    <Color x:Key="Color.Surface.CardElevated">#21262D</Color>
    <Color x:Key="Color.Surface.CardInverse">#111827</Color>
    <Color x:Key="Color.Surface.Overlay">#F0080D19</Color>
    <Color x:Key="Color.Surface.ModalScrim">#99000000</Color>

    <!-- Text -->
    <Color x:Key="Color.Text.Primary">#E6EDF3</Color>
    <Color x:Key="Color.Text.Secondary">#8B949E</Color>
    <Color x:Key="Color.Text.Tertiary">#6E7681</Color>
    <Color x:Key="Color.Text.OnAccent">#FFFFFF</Color>
    <Color x:Key="Color.Text.Muted">#94A3B8</Color>

    <!-- Border -->
    <Color x:Key="Color.Border.Default">#30363D</Color>
    <Color x:Key="Color.Border.Subtle">#21262D</Color>
    <Color x:Key="Color.Border.Strong">#388BFD</Color>
    <Color x:Key="Color.Border.WidgetCard">#1E293B</Color>

    <!-- Accent -->
    <Color x:Key="Color.Accent.Primary">#1F6FEB</Color>
    <Color x:Key="Color.Accent.PrimaryHover">#388BFD</Color>
    <Color x:Key="Color.Accent.PrimaryPressed">#1158C7</Color>
    <Color x:Key="Color.Accent.Link">#58A6FF</Color>

    <!-- Status -->
    <Color x:Key="Color.Status.Fresh">#34D399</Color>
    <Color x:Key="Color.Status.FreshSoft">#86EFAC</Color>
    <Color x:Key="Color.Status.Warning">#FBBF24</Color>
    <Color x:Key="Color.Status.Refreshing">#FBBF24</Color>
    <Color x:Key="Color.Status.Stale">#F59E0B</Color>
    <Color x:Key="Color.Status.Failed">#F87171</Color>
    <Color x:Key="Color.Status.FailedSoft">#FCA5A5</Color>
    <Color x:Key="Color.Status.FailedFaint">#FECACA</Color>
    <Color x:Key="Color.Status.Neutral">#94A3B8</Color>

    <!-- Urgency -->
    <Color x:Key="Color.Urgency.Critical">#FCA5A5</Color>
    <Color x:Key="Color.Urgency.High">#FBBF24</Color>
    <Color x:Key="Color.Urgency.Medium">#93C5FD</Color>
    <Color x:Key="Color.Urgency.Low">#34D399</Color>

    <!-- Brand -->
    <Color x:Key="Color.Brand.Claude">#E86F35</Color>
    <Color x:Key="Color.Brand.Codex">#10B981</Color>
    <Color x:Key="Color.Brand.Antigravity">#4285F4</Color>
    <Color x:Key="Color.Brand.Unknown">#6366F1</Color>

    <!-- Badge -->
    <Color x:Key="Color.Badge.Cloud.Fg">#93C5FD</Color>
    <Color x:Key="Color.Badge.Cloud.Bg">#1E293B</Color>
    <Color x:Key="Color.Badge.Cloud.Border">#3B82F6</Color>
    <Color x:Key="Color.Badge.Ide.Fg">#C4B5FD</Color>
    <Color x:Key="Color.Badge.Ide.Bg">#1E1B3B</Color>
    <Color x:Key="Color.Badge.Ide.Border">#7C3AED</Color>
    <Color x:Key="Color.Badge.FailureFg">#FECACA</Color>
    <Color x:Key="Color.Badge.FailureBg">#3B1F24</Color>
    <Color x:Key="Color.Badge.FailureBorder">#FCA5A5</Color>
    <Color x:Key="Color.Badge.OkFg">#86EFAC</Color>
    <Color x:Key="Color.Badge.OkBg">#10251C</Color>
    <Color x:Key="Color.Badge.OkBorder">#34D399</Color>

    <!-- Indicator -->
    <Color x:Key="Color.Indicator.Clean">#3FB950</Color>
    <Color x:Key="Color.Indicator.Dirty">#F87171</Color>

</ResourceDictionary>

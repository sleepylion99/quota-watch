<UserControl x:Class="AiLimit.App.Controls.AccountTrashView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="DangerButtonStyle"
               TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
            <Setter Property="Background" Value="{DynamicResource Brush.Status.Failed}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Badge.FailureBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.Status.FailedSoft}" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{DynamicResource Brush.Status.FailedFaint}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{DynamicResource Brush.Status.FailedSoft}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button MinWidth="104"
                    Height="30"
                    Padding="12,0"
                    Content="{Binding BackToAccountsText}"
                    Click="BackButton_Click" />
        </Grid>

        <Grid Grid.Row="1">
            <TextBlock Text="{Binding TrashEmptyText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="360">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TrashRows.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <Border Background="{DynamicResource Brush.Surface.Card}"
                    BorderBrush="{DynamicResource Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding TrashRows.Count}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Padding="14,10"
                            Background="{DynamicResource Brush.Surface.TitleBar}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="12,12,0,0">
                        <TextBlock Text="{Binding TrashButtonText}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontWeight="SemiBold"
                                   FontSize="11" />
                    </Border>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding TrashRows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,10"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding ProviderText}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding AccountText}"
                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                       FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DeletedAtText}"
                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="3"
                                                    MinWidth="72"
                                                    Height="28"
                                                    Margin="8,0,0,0"
                                                    Padding="10,0"
                                                    Tag="{Binding}"
                                                    Content="{Binding DataContext.RestoreText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Click="RestoreButton_Click" />
                                            <Button Grid.Column="4"
                                                    MinWidth="82"
                                                    Height="28"
                                                    Margin="6,0,0,0"
                                                    Padding="10,0"
                                                    Tag="{Binding}"
                                                    Content="{Binding DataContext.DeletePermanentlyText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Click="DeletePermanentlyButton_Click" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="PermanentDeleteOverlay"
              Grid.Row="0"
              Grid.RowSpan="2"
              Panel.ZIndex="30"
              Background="{DynamicResource Brush.Surface.ModalScrim}"
              Visibility="Collapsed">
            <Border Width="460"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Brush.Surface.Card}"
                    BorderBrush="{DynamicResource Brush.Badge.FailureBorder}"
                    BorderThickness="1"
                    CornerRadius="14">
                <StackPanel>
                    <Grid Margin="0,0,0,22">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="34"
                                Height="34"
                                Margin="0,1,14,0"
                                Background="{DynamicResource Brush.Badge.FailureBg}"
                                BorderBrush="{DynamicResource Brush.Badge.FailureBorder}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <TextBlock Text="!"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource Brush.Badge.FailureFg}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding PendingDeleteTitleText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                            <TextBlock Text="{Binding PendingDeleteMessageText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="12"
                                       LineHeight="18"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                    <StackPanel HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button MinWidth="90"
                                Height="36"
                                Margin="0,0,8,0"
                                Padding="14,0"
                                Content="{Binding CancelText}"
                                Click="CancelPermanentDeleteButton_Click" />
                        <Button x:Name="ConfirmPermanentDeleteButton"
                                MinWidth="118"
                                Height="36"
                                Padding="14,0"
                                Style="{StaticResource DangerButtonStyle}"
                                Content="{Binding DeletePermanentlyText}"
                                Click="ConfirmPermanentDeleteButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

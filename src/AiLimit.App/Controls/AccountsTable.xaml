<UserControl x:Class="AiLimit.App.Controls.AccountsTable"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="Transparent">
    <Grid Margin="0,4,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Action bar -->
        <Grid Grid.Row="0" Margin="0,10,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="PrimaryButton"
                    MinWidth="120"
                    Height="32"
                    Padding="12,0"
                    Content="{Binding PrimaryActionText}"
                    Click="PrimaryButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <!-- Antigravity uses "Sign in with Google" instead of IDE import. -->
                            <DataTrigger Binding="{Binding SupportsGoogleSignIn}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                            <!-- Claude uses "Sign in with Anthropic" instead of CLI import. -->
                            <DataTrigger Binding="{Binding SupportsClaudeSignIn}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button x:Name="RefreshButton"
                    Grid.Column="1"
                    MinWidth="100"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="12,0"
                    Content="{Binding RefreshAllButtonText}"
                    Click="RefreshButton_Click" />
            <!-- Google sign-in button (Antigravity tab only) -->
            <Button x:Name="GoogleSignInButton"
                    Grid.Column="2"
                    MinWidth="140"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="12,0"
                    Content="{Binding SignInWithGoogleText}"
                    Click="GoogleSignInButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SupportsGoogleSignIn}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- Sign in with Anthropic button (Claude tab only) -->
            <Button x:Name="ClaudeSignInButton"
                    Grid.Column="2"
                    MinWidth="160"
                    Height="32"
                    Margin="8,0,0,0"
                    Padding="12,0"
                    Content="{Binding SignInWithClaudeText}"
                    Click="ClaudeSignInButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SupportsClaudeSignIn}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- Trash (opens the recycle bin), grouped with the other action buttons. -->
            <Button x:Name="OpenTrashButton"
                    Grid.Column="3"
                    MinWidth="104"
                    Height="32"
                    Padding="12,0"
                    HorizontalAlignment="Right"
                    Content="{Binding DataContext.TrashButtonLabel, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                    Click="OpenTrashButton_Click" />
        </Grid>


        <!-- Row 1: sync error banner + Claude sign-in panel -->
        <StackPanel Grid.Row="1">
            <!-- Sync error banner -->
            <Border x:Name="SyncErrorBanner"
                    Margin="0,0,0,10"
                    Padding="12,8"
                    Background="{DynamicResource Brush.Badge.FailureBg}"
                    BorderBrush="{DynamicResource Brush.Badge.FailureBorder}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <TextBlock x:Name="SyncErrorText"
                           Foreground="{DynamicResource Brush.Badge.FailureFg}"
                           FontSize="11"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Claude "Sign in with Anthropic" panel (status + code paste) -->
            <Border x:Name="ClaudeSignInPanel"
                    Margin="0,0,0,10"
                    Padding="12,10"
                    Background="{DynamicResource Brush.Surface.Card}"
                    BorderBrush="{DynamicResource Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClaudeSignIn.ShowPanel}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding ClaudeSignIn.StatusMessage}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                    <Grid Margin="0,8,0,0">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ClaudeSignIn.AwaitingCode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ClaudeCodeBox"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ClaudeSignIn.PastedCode, UpdateSourceTrigger=PropertyChanged}" />
                        <Button x:Name="ClaudeSubmitCodeButton"
                                Grid.Column="1"
                                MinWidth="96"
                                Height="32"
                                Margin="8,0,0,0"
                                Padding="12,0"
                                Content="{Binding ClaudeSubmitCodeText}"
                                Click="ClaudeSubmitCodeButton_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Body: empty state OR rows -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <TextBlock x:Name="EmptyStateText"
                       Text="{Binding EmptyStateText}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource Brush.Text.Secondary}"
                       FontSize="12"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="360"
                       Visibility="Collapsed" />

            <!-- Row container -->
            <Border x:Name="RowContainer"
                    Background="{DynamicResource Brush.Surface.Card}"
                    BorderBrush="{DynamicResource Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Column header -->
                    <Border Grid.Row="0"
                            Padding="14,10"
                            Background="{DynamicResource Brush.Surface.TitleBar}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="12,12,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="154" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ColumnAccountText}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontWeight="SemiBold"
                                       FontSize="11" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ColumnStatusText}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontWeight="SemiBold"
                                       FontSize="11" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding ColumnPlanText}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontWeight="SemiBold"
                                       FontSize="11" />
                        </Grid>
                    </Border>

                    <!-- Rows -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Rows}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="14,10"
                                            BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="154" />
                            </Grid.ColumnDefinitions>

                                            <!-- Account column -->
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding AccountText}"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           FontSize="13"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Margin="8,0,0,0"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource Brush.Badge.OkBg}"
                                                        BorderBrush="{DynamicResource Brush.Badge.OkBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="4">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding DataContext.ActiveBadgeText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               Foreground="{DynamicResource Brush.Badge.OkFg}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>

                                            <!-- Status column -->
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>

                                            <!-- Plan column -->
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding PlanText}"
                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />

                                            <!-- Row actions -->
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center">
                                                <Button MinWidth="72"
                                                        Height="28"
                                                        Padding="10,0"
                                                        Tag="{Binding Id}"
                                                        Content="{Binding DataContext.SwitchButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Click="SwitchButton_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button MinWidth="72"
                                                        Height="28"
                                                        Margin="6,0,0,0"
                                                        Padding="10,0"
                                                        Tag="{Binding Id}"
                                                        Content="{Binding DataContext.TrashButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Click="TrashButton_Click">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding CanTrash}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

<Window x:Class="AiLimit.App.Windows.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AiLimit.App.Windows"
        Title="Quota Watch"
        Icon="/Assets/Icons/app.ico"
        Height="740"
        Width="1080"
        MinHeight="620"
        MinWidth="920"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent">
    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      ResizeBorderThickness="6"
                      CaptionHeight="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Border Margin="6"
            Background="{DynamicResource Brush.Surface.Window}"
            BorderBrush="{DynamicResource Brush.Border.Default}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Background="{DynamicResource Brush.Surface.TitleBar}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="18,0,0,0">
                    <TextBlock Text="Quota Watch"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="15"
                               FontWeight="Bold" />
                    <Ellipse Width="8"
                             Height="8"
                             Margin="10,0,0,0"
                             Fill="{Binding StatusBrush, Converter={StaticResource BrushKeyConverter}}" />
                </StackPanel>
                <StackPanel x:Name="DashboardTitleBarControls"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0">
                    <TextBlock Text="&#x25D0;"
                               FontSize="12"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text.Secondary}" />
                    <Slider x:Name="DashboardOpacitySlider"
                            Width="140"
                            VerticalAlignment="Center"
                            Minimum="{Binding WindowOpacityMinimumPercent, Mode=OneWay}"
                            Maximum="{Binding WindowOpacityMaximumPercent, Mode=OneWay}"
                            Value="{Binding DashboardOpacityPercent, Mode=OneWay}"
                            TickFrequency="5"
                            IsSnapToTickEnabled="True"
                            ValueChanged="DashboardOpacitySlider_ValueChanged" />
                    <TextBlock x:Name="DashboardOpacityValueText"
                               MinWidth="34"
                               Margin="6,0,16,0"
                               VerticalAlignment="Center"
                               TextAlignment="Right"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Brush.Accent.Link}" />
                    <ToggleButton x:Name="DashboardPinButton"
                                  Style="{StaticResource WindowPinToggleButtonStyle}"
                                  Margin="0,0,4,0"
                                  Content="&#xE718;"
                                  ToolTip="{Binding PinWindowTooltipText}"
                                  Click="DashboardPinButton_Click" />
                    <Button Style="{StaticResource WindowMinimizeButtonStyle}"
                            Margin="0,0,4,0"
                            Content="&#x2212;"
                            Click="MinimizeButton_Click" />
                    <Button Style="{StaticResource WindowCloseButtonStyle}"
                            Content="&#x00D7;"
                            Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Border x:Name="ThemeModeToggle"
                                Width="132"
                                Height="34"
                                Margin="0,2,10,2"
                                Background="{DynamicResource Brush.Surface.Card}"
                                BorderBrush="{DynamicResource Brush.Border.Default}"
                                BorderThickness="1"
                                CornerRadius="17"
                                ClipToBounds="True">
                            <Border.Resources>
                                <Style x:Key="ThemeModeButtonStyle" TargetType="Button">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="FontSize" Value="15" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Resources>
                            <Grid>
                                <Border x:Name="ThemeToggleThumb"
                                        Width="40"
                                        Height="28"
                                        Margin="3,2,0,2"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource Brush.Accent.Primary}"
                                        CornerRadius="14"
                                        IsHitTestVisible="False">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ThemeToggleThumbTransform" />
                                    </Border.RenderTransform>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="44" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0"
                                            Tag="Dark"
                                            Content="&#x263D;"
                                            Style="{StaticResource ThemeModeButtonStyle}"
                                            Click="ThemeModeButton_Click" />
                                    <Button Grid.Column="1"
                                            Tag="System"
                                            Content="A"
                                            Click="ThemeModeButton_Click"
                                            FontWeight="Bold"
                                            Style="{StaticResource ThemeModeButtonStyle}" />
                                    <Button Grid.Column="2"
                                            Tag="Light"
                                            Content="&#x2600;"
                                            Click="ThemeModeButton_Click"
                                            Style="{StaticResource ThemeModeButtonStyle}" />
                                </Grid>
                            </Grid>
                        </Border>
                        <Button x:Name="SettingsButton"
                                MinWidth="92"
                                Height="38"
                                Margin="0,0,10,0"
                                Padding="12,0"
                                Content="{Binding SettingsButtonText}"
                                Click="SettingsButton_Click" />
                        <Button MinWidth="132"
                                Height="38"
                                Margin="0,0,10,0"
                                Content="{Binding ToggleWidgetButtonText}"
                                Click="ToggleWidgetButton_Click" />
                        <Button MinWidth="104"
                                Height="38"
                                Content="{Binding RefreshAllButtonText}"
                                Click="RefreshButton_Click" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Padding="18"
                        Background="{DynamicResource Brush.Surface.Card}"
                        BorderBrush="{DynamicResource Brush.Border.Default}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.6*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding TrackedLabel}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding HeaderTitle}"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       FontSize="22"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding OverallStatusLabel}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="{Binding StatusBrush, Converter={StaticResource BrushKeyConverter}}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding LastCheckedLabel}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="12" />
                            <TextBlock Text="{Binding CheckedAtText}"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       FontSize="16" />
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="{Binding GuidanceTitle}"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding GuidanceDetail}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="12"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding GuidanceAction}"
                                       Foreground="{DynamicResource Brush.Accent.Link}"
                                       FontSize="12"
                                       Margin="0,5,0,0"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer x:Name="ProviderScrollViewer"
                              Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ProviderItemsControl"
                                  ItemsSource="{Binding Providers}"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <local:TwoColumnPanel ColumnGap="18" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="VerticalAlignment" Value="Top" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border MinHeight="215"
                                        VerticalAlignment="Top"
                                        Margin="0,0,0,18"
                                        Background="{DynamicResource Brush.Surface.Card}"
                                        BorderBrush="{DynamicResource Brush.Border.Default}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="3" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="{Binding BrandColorBrush, Converter={StaticResource BrushKeyConverter}}"
                                                CornerRadius="7,7,0,0" />
                                        <StackPanel Grid.Row="1"
                                                    Margin="18,14,18,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding ProviderName}"
                                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Border Padding="8,3"
                                                        Margin="0,8,0,0"
                                                        HorizontalAlignment="Left"
                                                        Background="{DynamicResource Brush.Surface.CardElevated}"
                                                        BorderBrush="{DynamicResource Brush.Border.Default}"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <TextBlock Text="{Binding LimitProfileText}"
                                                               ToolTip="{Binding LimitProfileToolTipText}"
                                                               Foreground="{DynamicResource Brush.Text.Secondary}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Right">
                                                    <Border Padding="8,3"
                                                            Margin="0,0,6,0"
                                                            Background="{Binding SourceBadgeBackground, Converter={StaticResource BrushKeyConverter}}"
                                                            BorderBrush="{Binding SourceBadgeBorderBrush, Converter={StaticResource BrushKeyConverter}}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowSourceBadge}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding SourceBadgeText}"
                                                                   ToolTip="{Binding SourceBadgeToolTipText}"
                                                                   Foreground="{Binding SourceBadgeForeground, Converter={StaticResource BrushKeyConverter}}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Padding="8,3"
                                                            Background="{Binding StatusBadgeBackground, Converter={StaticResource BrushKeyConverter}}"
                                                            BorderBrush="{Binding StatusBadgeBorderBrush, Converter={StaticResource BrushKeyConverter}}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <TextBlock Text="{Binding StatusBadgeText}"
                                                                   ToolTip="{Binding StatusBadgeToolTipText}"
                                                                   Foreground="{Binding StatusBadgeForeground, Converter={StaticResource BrushKeyConverter}}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Padding="8,3"
                                                            Margin="6,0,0,0"
                                                            Background="{DynamicResource Brush.Badge.FailureBg}"
                                                            BorderBrush="{DynamicResource Brush.Badge.FailureBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowNoValueBadge}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding NoValueBadgeText}"
                                                                   ToolTip="{Binding NoValueBadgeToolTipText}"
                                                                   Foreground="{DynamicResource Brush.Badge.FailureFg}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{Binding AutoRetryText}"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           FontSize="11"
                                                           Margin="0,6,0,0"
                                                           HorizontalAlignment="Right">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowAutoRetryText}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="{Binding LastErrorText}"
                                                   Foreground="{DynamicResource Brush.Status.FailedSoft}"
                                                   FontSize="11"
                                                   Margin="0,12,0,0"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasLastErrorText}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Grid Margin="0,16,0,14">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowPrimarySummary}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding PrimaryLabel}"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           FontSize="11"
                                                           LineHeight="15" />
                                                <TextBlock Text="{Binding ResetText}"
                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                           FontSize="11"
                                                           Margin="0,4,0,0"
                                                           LineHeight="15"
                                                           TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding PrimaryPercentText}"
                                                       Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}"
                                                       VerticalAlignment="Center"
                                                       FontSize="20"
                                                       FontWeight="SemiBold" />
                                        </Grid>

                                        <ProgressBar Value="{Binding PrimaryPercent, Mode=OneWay}"
                                                     Maximum="100"
                                                     Margin="0,0,0,4"
                                                     Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar"
                                                       BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowPrimaryProgress}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>
                                        <ItemsControl ItemsSource="{Binding VisibleWindows}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Setter Property="Margin" Value="0,16,0,0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowPrimarySummary}" Value="True">
                                                            <Setter Property="Margin" Value="0" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,12">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Opacity" Value="1" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsLowConfidence}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.55" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Label}"
                                                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                           FontSize="12"
                                                                           LineHeight="16" />
                                                                <TextBlock Text="{Binding ResetText}"
                                                                           Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                                           FontSize="11"
                                                                           Margin="0,4,0,0"
                                                                           LineHeight="15"
                                                                           TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding PercentText}"
                                                                       Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold" />
                                                        </Grid>
                                                        <ProgressBar Value="{Binding PercentValue, Mode=OneWay}"
                                                                     Maximum="100"
                                                                     Margin="0,8,0,0"
                                                                     Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar"
                                                                       BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ShowBar}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="{Binding ExpandButtonText}"
                                                Tag="{Binding}"
                                                Click="ToggleExpandButton_Click"
                                                Margin="0,6,0,0"
                                                Height="28"
                                                Padding="10,0"
                                                HorizontalAlignment="Left">
                                            <Button.Style>
                                                <Style TargetType="Button"
                                                       BasedOn="{StaticResource {x:Type Button}}">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface.CardElevated}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                                    <Setter Property="FontSize" Value="11" />
                                                    <Setter Property="FontWeight" Value="Normal" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ShowExpandToggle}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Border>
</Window>

<Window x:Class="AiLimit.App.Windows.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quota Watch Widget"
        Icon="/Assets/Icons/app.ico"
        Width="520"
        Height="440"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        Topmost="False">
    <Border Margin="8"
            Padding="18"
            Background="{DynamicResource Brush.Surface.Overlay}"
            BorderBrush="{DynamicResource Brush.Border.Default}"
            BorderThickness="1"
            CornerRadius="24"
            MouseLeftButtonDown="Widget_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="10" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding HeaderTitle}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontSize="18"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{Binding StatusBrush, Converter={StaticResource BrushKeyConverter}}"
                               FontSize="12" />
                    <TextBlock Text="{Binding WidgetGuidanceText}"
                               Foreground="{DynamicResource Brush.Text.Muted}"
                               FontSize="11"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal">
                    <ToggleButton x:Name="WidgetPinButton"
                                  Style="{StaticResource WindowPinToggleButtonStyle}"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  Content="&#xE718;"
                                  ToolTip="{Binding PinWindowTooltipText}"
                                  Click="WidgetPinButton_Click" />
                    <Button Width="116"
                            Height="32"
                            Margin="0,0,8,0"
                            Padding="8,0"
                            Content="{Binding DashboardButtonText}"
                            Click="OpenDashboardButton_Click" />
                    <Button Width="84"
                            Height="32"
                            Margin="0,0,8,0"
                            Padding="8,0"
                            Content="{Binding RefreshButtonText}"
                            Click="RefreshButton_Click" />
                    <Button Width="66"
                            Height="32"
                            Padding="8,0"
                            Content="{Binding HideButtonText}"
                            Click="HideButton_Click" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,10,0,0">
                <TextBlock Text="&#x25D0;"
                           FontSize="13"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.Text.Muted}" />
                <Slider x:Name="WidgetOpacitySlider"
                        Width="170"
                        VerticalAlignment="Center"
                        Minimum="{Binding WindowOpacityMinimumPercent, Mode=OneWay}"
                        Maximum="{Binding WindowOpacityMaximumPercent, Mode=OneWay}"
                        Value="{Binding WidgetOpacityPercent, Mode=OneWay}"
                        TickFrequency="5"
                        IsSnapToTickEnabled="True"
                        ValueChanged="WidgetOpacitySlider_ValueChanged" />
                <TextBlock x:Name="WidgetOpacityValueText"
                           MinWidth="36"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Accent.Link}" />
            </StackPanel>

            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Providers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,10,10"
                                    Padding="12"
                                    Background="{DynamicResource Brush.Surface.CardInverse}"
                                    BorderBrush="{DynamicResource Brush.Border.WidgetCard}"
                                    BorderThickness="1"
                                    CornerRadius="15">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock Text="{Binding ProviderName}"
                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding PrimaryLabel}"
                                                       Foreground="{DynamicResource Brush.Text.Muted}"
                                                       FontSize="11"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ResetText}"
                                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                       FontSize="10"
                                                       Margin="0,2,0,0"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PrimaryPercentText}"
                                                   Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}"
                                                   FontSize="15"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right" />
                                    </Grid>
                                    <ItemsControl ItemsSource="{Binding VisibleWindows}"
                                                  Margin="0,8,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Label}"
                                                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                                                       FontSize="11" />
                                                            <TextBlock Text="{Binding ResetText}"
                                                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                                       FontSize="10"
                                                                       Margin="0,2,0,0"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding PercentText}"
                                                                   Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold" />
                                                    </Grid>
                                                    <ProgressBar Value="{Binding PercentValue, Mode=OneWay}"
                                                                 Maximum="100"
                                                                 Margin="0,6,0,0"
                                                                 Foreground="{Binding UrgencyBrush, Converter={StaticResource BrushKeyConverter}}">
                                                        <ProgressBar.Style>
                                                            <Style TargetType="ProgressBar"
                                                                   BasedOn="{StaticResource {x:Type ProgressBar}}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ShowBar}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ProgressBar.Style>
                                                    </ProgressBar>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Button Click="ShowMoreHint_Click"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Left">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Setter Property="Cursor" Value="Hand" />
                                                <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <TextBlock Text="{Binding HiddenWindowHintText}"
                                                                       Foreground="{DynamicResource Brush.Text.Tertiary}"
                                                                       FontSize="10" />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ShowExpandToggle}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>

<Window x:Class="AiLimit.App.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quota Watch Settings"
        Width="580"
        Height="760"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border Margin="8"
            Background="{DynamicResource Brush.Surface.Window}"
            BorderBrush="{DynamicResource Brush.Border.Default}"
            BorderThickness="1"
            CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="SettingsTitleBar"
                    Padding="18,0,10,0"
                    Background="{DynamicResource Brush.Surface.TitleBar}"
                    CornerRadius="11,11,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Quota Watch"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="15"
                                   FontWeight="Bold" />
                        <Ellipse x:Name="SettingsStatusEllipse"
                                 Width="7"
                                 Height="7"
                                 Margin="9,1,0,0"
                                 Fill="{DynamicResource Brush.Indicator.Clean}" />
                    </StackPanel>
                    <StackPanel x:Name="SettingsTitleBarControls"
                                Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource WindowMinimizeButtonStyle}"
                                Margin="0,0,4,0"
                                Content="&#x2212;"
                                Click="SettingsMinimizeButton_Click" />
                        <Button Style="{StaticResource WindowCloseButtonStyle}"
                                Content="&#x00D7;"
                                Click="SettingsCloseButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,18,20,20">
                    <TextBlock Text="{Binding SettingsButtonText}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="Bold"
                               FontSize="20" />
                    <TextBlock Text="{Binding SettingsPanelDetailText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,4,0,16"
                               TextWrapping="Wrap" />

                    <Border x:Name="ProvidersSettingsCard"
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Brush.Surface.Card}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="{Binding ModelSettingsButtonText}"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       FontWeight="SemiBold"
                                       FontSize="13" />
                            <TextBlock Text="{Binding ModelSettingsDetailText}"
                                       Foreground="{DynamicResource Brush.Text.Secondary}"
                                       FontSize="11"
                                       Margin="0,3,0,12"
                                       TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding ProviderSettings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0"
                                              Margin="0,2,10,0"
                                              VerticalAlignment="Top"
                                              IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                              Tag="{Binding Id}"
                                              Click="ProviderSettingCheckBox_Click" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Id}"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   FontSize="11" />
                                        <TextBlock Text="{Binding SetupHintText}"
                                                   Foreground="{DynamicResource Brush.Accent.Link}"
                                                   FontSize="11"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSetupHint}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Margin="0,4,0,0"
                                    Height="30"
                                    Padding="14,0"
                                    HorizontalAlignment="Left"
                                    Content="{Binding AccountsButtonText}"
                                    Click="OpenAccountsWindowButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="AntigravityOAuthSettingsCard"
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Brush.Surface.Card}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Text="{Binding SettingsAntigravityMovedToAccountsText}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="11"
                                   TextWrapping="Wrap" />
                    </Border>

                    <Border x:Name="LanguageSettingsCard"
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Brush.Surface.Card}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="{Binding LanguageSettingsTitleText}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    <TextBlock Text="{Binding LanguageSettingsDetailText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,3,0,10"
                               TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding LanguageOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="62"
                                        Height="34"
                                        Margin="0,0,8,8"
                                        Content="{Binding Code}"
                                        ToolTip="{Binding Label}"
                                        Tag="{Binding Language}"
                                        Click="LanguageOptionButton_Click">
                                    <Button.Style>
                                        <Style TargetType="Button"
                                               BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Surface.Card}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.PrimaryHover}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="LimitWarningSettingsCard"
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Brush.Surface.Card}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="{Binding LimitWarningSettingsTitleText}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    <TextBlock Text="{Binding LimitWarningSettingsDetailText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,3,0,10"
                               TextWrapping="Wrap" />
                    <CheckBox IsChecked="{Binding IsLimitWarningEnabled, Mode=OneWay}"
                              Content="{Binding LimitWarningEnabledText}"
                              Foreground="{DynamicResource Brush.Text.Secondary}"
                              Margin="0,0,0,10"
                              Click="LimitWarningEnabledCheckBox_Click" />
                    <CheckBox x:Name="InactiveAccountWarningCheckBox"
                              IsChecked="{Binding IsInactiveAccountWarningEnabled, Mode=OneWay}"
                              Content="{Binding InactiveAccountWarningText}"
                              Foreground="{DynamicResource Brush.Text.Secondary}"
                              Margin="0,0,0,4"
                              Click="InactiveAccountWarningCheckBox_Click" />
                    <TextBlock Text="{Binding InactiveAccountWarningHintText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,0,0,10"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LimitWarningThresholdText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding LimitWarningProviderSettings}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        Background="{DynamicResource Brush.Surface.Window}"
                                        BorderBrush="{DynamicResource Brush.Border.Default}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <DockPanel Margin="0,0,0,8"
                                                   LastChildFill="False">
                                            <TextBlock Text="{Binding ProviderName}"
                                                       DockPanel.Dock="Left"
                                                       Margin="0,0,12,0"
                                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                                       FontWeight="SemiBold"
                                                       FontSize="12" />
                                            <TextBlock Text="{Binding ValueText}"
                                                       DockPanel.Dock="Right"
                                                       Foreground="{DynamicResource Brush.Accent.Link}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </DockPanel>
                                        <WrapPanel Margin="0,0,0,8">
                                            <ItemsControl ItemsSource="{Binding Recommendations}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Height="30"
                                                                Margin="0,0,6,6"
                                                                Padding="9,0"
                                                                Content="{Binding Label}"
                                                                Click="LimitWarningRecommendationButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button"
                                                                       BasedOn="{StaticResource {x:Type Button}}">
                                                                    <Setter Property="Background" Value="{DynamicResource Brush.Surface.Card}" />
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}" />
                                                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.PrimaryHover}" />
                                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <Button Height="30"
                                                    Margin="0,0,6,6"
                                                    Padding="9,0"
                                                    Content="{Binding CustomLabel}"
                                                    Click="LimitWarningCustomButton_Click">
                                                <Button.Style>
                                                    <Style TargetType="Button"
                                                           BasedOn="{StaticResource {x:Type Button}}">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.Surface.Card}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border.Default}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Secondary}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCustom}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource Brush.Accent.Primary}" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent.PrimaryHover}" />
                                                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text.OnAccent}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </WrapPanel>
                                        <Slider Minimum="1"
                                                Maximum="99"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                IsEnabled="{Binding IsSliderEnabled}"
                                                Value="{Binding ThresholdPercent, Mode=OneWay}"
                                                ValueChanged="LimitWarningSlider_ValueChanged" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="UpdateSettingsCard"
                            Margin="0,0,0,12"
                            Padding="16"
                            Background="{DynamicResource Brush.Surface.Card}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="{Binding UpdateCheckTitleText}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    <TextBlock Text="{Binding UpdateCheckDetailText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,3,0,10"
                               TextWrapping="Wrap" />
                            <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button MinWidth="122"
                                Height="34"
                                HorizontalAlignment="Left"
                                Padding="12,0"
                                Content="{Binding CheckForUpdatesButtonText}"
                                Click="CheckForUpdatesButton_Click" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding UpdateCheckStatusText}"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="11"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   TextWrapping="Wrap" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DiagnosticSettingsCard"
                            Padding="16"
                            Background="{DynamicResource Brush.Surface.Card}"
                            BorderBrush="{DynamicResource Brush.Border.Default}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <StackPanel>
                            <TextBlock Text="{Binding DiagnosticLogTitleText}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="SemiBold"
                               FontSize="13" />
                    <TextBlock Text="{Binding DiagnosticLogDetailText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               Margin="0,3,0,10"
                               TextWrapping="Wrap" />
                            <Button MinWidth="122"
                             Height="34"
                             HorizontalAlignment="Left"
                             Padding="12,0"
                             Content="{Binding CopyDiagnosticLogButtonText}"
                             Click="CopyDiagnosticLogButton_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="SettingsActionFooter"
                    Grid.Row="2"
                    Padding="20,14"
                    Background="{DynamicResource Brush.Surface.TitleBar}"
                    BorderBrush="{DynamicResource Brush.Surface.CardElevated}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,11,11">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{Binding SettingsImmediateApplyText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <Button MinWidth="84"
                                Height="34"
                                Margin="0,0,8,0"
                                Padding="12,0"
                                Content="{Binding SettingsCloseButtonText}"
                                Click="SettingsCloseButton_Click" />
                        <Button MinWidth="84"
                                Height="34"
                                Padding="12,0"
                                Background="{DynamicResource Brush.Accent.Primary}"
                                BorderBrush="{DynamicResource Brush.Accent.PrimaryHover}"
                                Content="{Binding SettingsApplyButtonText}"
                                Click="SettingsApplyButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="UpdateAvailableOverlay"
                  Grid.Row="0"
                  Grid.RowSpan="3"
                  Panel.ZIndex="30"
                  Background="{DynamicResource Brush.Surface.ModalScrim}"
                  Visibility="Collapsed">
                <Border Width="390"
                        Padding="22"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource Brush.Surface.Window}"
                        BorderBrush="{DynamicResource Brush.Accent.Primary}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel>
                        <TextBlock Text="{Binding UpdateAvailableTitleText}"
                                   Foreground="{DynamicResource Brush.Text.Primary}"
                                   FontSize="18"
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding UpdateAvailableMessageText}"
                                   Margin="0,9,0,22"
                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                   FontSize="12"
                                   LineHeight="18"
                                   TextWrapping="Wrap" />
                        <StackPanel HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button MinWidth="90"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Padding="14,0"
                                    Content="{Binding UpdateAvailableCancelButtonText}"
                                    Click="CancelUpdateButton_Click" />
                            <Button x:Name="ConfirmUpdateButton"
                                    MinWidth="136"
                                    Height="36"
                                    Padding="14,0"
                                    Background="{DynamicResource Brush.Accent.Primary}"
                                    BorderBrush="{DynamicResource Brush.Accent.PrimaryHover}"
                                    Content="{Binding UpdateAvailableConfirmButtonText}"
                                    Click="ConfirmUpdateButton_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Unsaved changes confirmation overlay -->
            <Border x:Name="UnsavedChangesPanel"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Panel.ZIndex="20"
                    Padding="18"
                    Width="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource Brush.Surface.Window}"
                    BorderBrush="{DynamicResource Brush.Border.Default}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="{Binding SettingsUnsavedTitleText}"
                               Foreground="{DynamicResource Brush.Text.Primary}"
                               FontWeight="Bold"
                               FontSize="16" />
                    <TextBlock Text="{Binding SettingsUnsavedDetailText}"
                               Foreground="{DynamicResource Brush.Text.Secondary}"
                               FontSize="12"
                               Margin="0,8,0,18"
                               TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button MinWidth="92"
                                Height="34"
                                Margin="0,0,8,0"
                                Padding="12,0"
                                Content="{Binding SettingsKeepEditingButtonText}"
                                Click="KeepEditingSettingsButton_Click" />
                        <Button MinWidth="92"
                                Height="34"
                                Padding="12,0"
                                Content="{Binding SettingsDiscardButtonText}"
                                Click="DiscardSettingsButton_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
